  <script>
    document.getElementById('y').textContent = new Date().getFullYear();

    function trackReviewClick(platform) {
      if (typeof gtag === 'function') {
        gtag('event', 'review_click', {
          event_category: 'engagement',
          event_label: platform,
          platform: platform
        });
      }
      console.log('Review/share click:', platform);
    }

    document.querySelectorAll('[data-platform]').forEach(link => {
      link.addEventListener('click', () => trackReviewClick(link.dataset.platform));
    });

    const shareBtn = document.getElementById('shareBtn');
    const shareData = {
      title: 'HydroSeal Paver Sealing',
      text: 'HydroSeal did an awesome job. If you need paver sealing or restoration in Jacksonville, check them out.',
      url: 'https://hydrosealpavers.com/'
    };

    shareBtn.addEventListener('click', async () => {
      trackReviewClick('share');

      if (navigator.share) {
        try {
          await navigator.share(shareData);
        } catch (e) {}
      } else {
        try {
          await navigator.clipboard.writeText(`${shareData.text} ${shareData.url}`);
          const strong = shareBtn.querySelector('.review-choice-copy strong');
          const original = strong.textContent;
          strong.textContent = 'Link copied — share it anywhere';
          setTimeout(() => { strong.textContent = original; }, 2200);
        } catch (e) {
          window.location.href = shareData.url;
        }
      }
    });
  </script>

